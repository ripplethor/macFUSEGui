    "Network unavailable. Disconnected to avoid stale mount hangs. Will reconnect when network returns.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Network unavailable. Disconnected to avoid stale mount hangs. Will reconnect when network returns."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Netzwerk nicht verfügbar. Zur Vermeidung blockierter Alt-Mounts wurde die Verbindung getrennt. Bei Netzrückkehr wird erneut verbunden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La red no está disponible. Se desconectó para evitar bloqueos por montajes obsoletos. Se reconectará cuando vuelva la red."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réseau indisponible. Déconnexion pour éviter les blocages de montages obsolètes. Reconnexion au retour du réseau."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワークを利用できません。古いマウントのハングを避けるため切断しました。ネットワーク復帰時に再接続します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "네트워크를 사용할 수 없습니다. 오래된 마운트로 인한 멈춤을 막기 위해 연결을 해제했습니다. 네트워크가 돌아오면 다시 연결합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Rede indisponível. Desconectado para evitar travamentos de montagens obsoletas. A conexão será restabelecida quando a rede voltar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "网络不可用。已断开连接以避免陈旧挂载导致卡死。网络恢复后将重新连接。"
          }
        }
      }
    },
